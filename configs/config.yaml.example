telegram:
  address_api: "https://api.telegram.org"
  secret_key: "123456789:AAH_example_token_here"
  poll_interval: 3s          # интервал опроса (для Long Polling)
  parse_mode: "HTML"         # HTML или Markdown
  allowed_updates:           # какие обновления получать
    - message
    - edited_message
    - callback_query
    - inline_query

db_config:
  schema: "public"
  dbname: "talktracer"
  user: "talktracer_user"
  password: "super_secret_password"
  nodes:
    - "127.0.0.1:5435"